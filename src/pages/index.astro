    <script>
      // Nav dark/light via IntersectionObserver
      const nav  = document.getElementById('nav');
      const hero = document.getElementById('hero');
      if (nav && hero) {
        const sentinel = document.createElement('div');
        sentinel.style.cssText = 'position:absolute;bottom:0;height:1px;width:100%;pointer-events:none;';
        hero.style.position = 'relative';
        hero.appendChild(sentinel);
        new IntersectionObserver(
          ([e]) => nav.classList.toggle('nav--light', !e.isIntersecting),
          { threshold: 0 }
        ).observe(sentinel);
      }

      // Scroll reveals
      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal,.reveal-scale,.reveal-x,.pourquoi-deco-photo')
        .forEach(el => obs.observe(el));
    </script>

