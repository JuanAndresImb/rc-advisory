---
// R&C Advisory — Page vitrine single-page
// Astro minimal, CSS vanilla, mobile-first
// Hero dramatique sombre inspiré de Floria, bento asymétrique, section process dark
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="R&C Advisory — Expert-comptable 100% digital à Bruxelles. Comptabilité, conseil fiscal et accompagnement personnalisé pour indépendants et PME en Belgique." />
    <title>R&C Advisory — Expert-comptable digital à Bruxelles</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <style>
      /* ── Fonts ─────────────────────────────────────────── */
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

      /* ── Tokens ────────────────────────────────────────── */
      :root {
        --bg:           #F5F6F8;
        --surface:      #FFFFFF;
        --dark:         #09090B;
        --dark-mid:     #0F1419;
        --text:         #0F1419;
        --muted:        #6B7280;
        --accent:       #2B5FE8;
        --accent-dk:    #1E47C8;
        --accent-pale:  #EEF2FE;
        --border:       rgba(15,20,25,0.08);
        --border-dark:  rgba(255,255,255,0.08);
        --r-xl:         24px;
        --r-2xl:        32px;
        --r-btn:        100px;
        --font:         'Outfit', system-ui, sans-serif;
        --max-w:        1280px;
        --nav-h:        72px;
        --shadow-sm:    0 1px 3px rgba(15,20,25,0.06), 0 4px 12px rgba(15,20,25,0.05);
        --shadow-md:    0 4px 16px rgba(15,20,25,0.10), 0 12px 40px rgba(15,20,25,0.08);
      }

      /* ── Reset ─────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }

      /* ── Container ─────────────────────────────────────── */
      .wrap {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 28px;
      }

      /* ─────────────────────────────────────────────────────
         NAV
      ───────────────────────────────────────────────────── */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        height: var(--nav-h);
        display: flex;
        align-items: center;
        transition: background 0.4s ease, border-color 0.4s ease;
        background: transparent;
        border-bottom: 1px solid transparent;
      }
      .nav.nav--light {
        background: rgba(245,246,248,0.90);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom-color: var(--border);
      }
      .nav .wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      .nav-logo {
        font-size: 1.125rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #fff;
        transition: color 0.4s ease;
      }
      .nav--light .nav-logo { color: var(--text); }
      .nav-logo span { color: var(--accent); }
      .btn-nav {
        display: inline-flex;
        align-items: center;
        padding: 10px 22px;
        border-radius: var(--r-btn);
        background: #fff;
        color: var(--text);
        font-family: var(--font);
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.18s, transform 0.12s, color 0.18s;
      }
      .nav--light .btn-nav {
        background: var(--accent);
        color: #fff;
      }
      .btn-nav:hover { opacity: 0.88; }
      .btn-nav:active { transform: scale(0.98); }

      /* ─────────────────────────────────────────────────────
         HERO — dark dramatique
      ───────────────────────────────────────────────────── */
      .hero {
        position: relative;
        min-height: 100dvh;
        background: var(--dark);
        display: flex;
        align-items: center;
        padding-top: var(--nav-h);
        overflow: hidden;
        z-index: 10;
      }

      /* Dot grid subtil */
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.035) 1px, transparent 1px);
        background-size: 36px 36px;
        pointer-events: none;
      }

      /* Fondue bas du hero vers le fond clair */
      .hero-fade {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 180px;
        background: linear-gradient(to top, var(--bg), transparent);
        pointer-events: none;
        z-index: 5;
      }

      /* Éléments décoratifs CSS */
      .hero-deco {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 1;
      }
      /* Grand cercle creux droit */
      .hero-deco::before {
        content: '';
        position: absolute;
        right: -10%;
        top: 10%;
        width: clamp(400px, 55vw, 760px);
        height: clamp(400px, 55vw, 760px);
        border-radius: 50%;
        border: 1px solid rgba(43,95,232,0.12);
      }
      /* Cercle plus petit décalé */
      .hero-deco::after {
        content: '';
        position: absolute;
        right: 5%;
        top: 25%;
        width: clamp(200px, 28vw, 380px);
        height: clamp(200px, 28vw, 380px);
        border-radius: 50%;
        background: radial-gradient(circle, rgba(43,95,232,0.06) 0%, transparent 70%);
      }
      /* Monogramme décoratif grand format */
      .hero-monogram {
        position: absolute;
        right: -2%;
        top: 50%;
        transform: translateY(-50%);
        font-size: clamp(200px, 28vw, 400px);
        font-weight: 800;
        letter-spacing: -0.06em;
        line-height: 1;
        color: rgba(255,255,255,0.025);
        user-select: none;
        pointer-events: none;
      }
      /* Petite ligne horizontale accent */
      .hero-line {
        position: absolute;
        left: 28px;
        bottom: 220px;
        width: 80px;
        height: 1px;
        background: rgba(43,95,232,0.4);
      }

      .hero .wrap {
        position: relative;
        z-index: 10;
        padding-top: 72px;
        padding-bottom: 140px;
      }
      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 14px;
        border-radius: var(--r-btn);
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.07);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.7);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        margin-bottom: 28px;
      }
      .hero-eyebrow-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
      }
      .hero-title {
        font-size: clamp(3rem, 7.5vw, 6.25rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 0.93;
        color: #fff;
        margin-bottom: 28px;
        max-width: 16ch;
      }
      .hero-title em {
        font-style: italic;
        font-weight: 300;
        color: rgba(255,255,255,0.45);
      }
      .hero-sub {
        font-size: clamp(1rem, 1.5vw, 1.125rem);
        color: rgba(255,255,255,0.55);
        line-height: 1.7;
        max-width: 42ch;
        margin-bottom: 40px;
      }
      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
      }
      .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 15px 30px;
        border-radius: var(--r-btn);
        background: #fff;
        color: var(--dark);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.18s, transform 0.12s, box-shadow 0.18s;
      }
      .btn-primary:hover { background: rgba(255,255,255,0.92); }
      .btn-primary:active { transform: scale(0.98); }
      .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 14px 26px;
        border-radius: var(--r-btn);
        background: transparent;
        color: rgba(255,255,255,0.7);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 500;
        border: 1px solid rgba(255,255,255,0.18);
        cursor: pointer;
        white-space: nowrap;
        transition: border-color 0.18s, background 0.18s, color 0.18s, transform 0.12s;
      }
      .btn-ghost:hover {
        border-color: rgba(255,255,255,0.38);
        background: rgba(255,255,255,0.06);
        color: #fff;
      }
      .btn-ghost:active { transform: scale(0.98); }

      /* Stats hero (deux chiffres clés) */
      .hero-stats {
        display: flex;
        gap: 40px;
        margin-top: 56px;
        padding-top: 40px;
        border-top: 1px solid rgba(255,255,255,0.08);
        flex-wrap: wrap;
      }
      .hero-stat-num {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: #fff;
        line-height: 1;
        margin-bottom: 4px;
      }
      .hero-stat-label {
        font-size: 0.8125rem;
        color: rgba(255,255,255,0.4);
        line-height: 1.4;
        max-width: 18ch;
      }

      /* ─────────────────────────────────────────────────────
         REVEAL ANIMATIONS (Intersection Observer)
      ───────────────────────────────────────────────────── */
      .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-scale {
        opacity: 0;
        transform: scale(0.96);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-x {
        opacity: 0;
        transform: translateX(-24px);
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible, .reveal-scale.visible, .reveal-x.visible {
        opacity: 1;
        transform: none;
      }
      .d1 { transition-delay: 0.06s; }
      .d2 { transition-delay: 0.12s; }
      .d3 { transition-delay: 0.18s; }
      .d4 { transition-delay: 0.26s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal, .reveal-scale, .reveal-x {
          opacity: 1; transform: none; transition: none;
        }
      }

      /* ─────────────────────────────────────────────────────
         SERVICES — bento asymétrique sur fond clair
      ───────────────────────────────────────────────────── */
      .services {
        position: relative;
        z-index: 20;
        background: var(--bg);
        padding: 96px 0 112px;
      }
      .services-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 32px;
        margin-bottom: 52px;
        flex-wrap: wrap;
      }
      .section-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 1.08;
        color: var(--text);
      }
      .services-header-right {
        max-width: 36ch;
        color: var(--muted);
        font-size: 0.9375rem;
        line-height: 1.65;
        flex-shrink: 0;
      }

      /* Bento grid asymétrique */
      .bento {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: 300px 240px;
        gap: 16px;
      }
      .bento-tile {
        position: relative;
        border-radius: var(--r-2xl);
        overflow: hidden;
        cursor: default;
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.3s ease;
      }
      .bento-tile:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

      /* Tile 1 : 100% Digital — grand, sombre */
      .tile-digital {
        grid-column: 1 / 8;
        grid-row: 1;
        background: linear-gradient(135deg, #0F1B35 0%, #0F2356 100%);
        padding: 36px 40px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .tile-digital::before {
        content: '100%';
        position: absolute;
        right: -12px;
        bottom: -32px;
        font-size: clamp(120px, 16vw, 200px);
        font-weight: 800;
        letter-spacing: -0.06em;
        line-height: 1;
        color: rgba(43,95,232,0.1);
        pointer-events: none;
        user-select: none;
      }

      /* Tile 2 : Expertise-comptable */
      .tile-compta {
        grid-column: 8 / 13;
        grid-row: 1;
        background: var(--surface);
        border: 1.5px solid var(--border);
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      /* Tile 3 : Conseil fiscal */
      .tile-fiscal {
        grid-column: 1 / 6;
        grid-row: 2;
        background: var(--accent);
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      /* Tile 4 : Accompagnement */
      .tile-accomp {
        grid-column: 6 / 13;
        grid-row: 2;
        background: var(--surface);
        border: 1.5px solid var(--border);
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }

      .tile-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: auto;
      }
      .tile-tag-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
      }
      /* Dark tile tags */
      .tile-digital .tile-tag { color: rgba(255,255,255,0.45); }
      .tile-digital .tile-tag-dot { background: rgba(43,95,232,0.7); }
      /* Accent tile tags */
      .tile-fiscal .tile-tag { color: rgba(255,255,255,0.6); }
      .tile-fiscal .tile-tag-dot { background: rgba(255,255,255,0.5); }
      /* Light tile tags */
      .tile-compta .tile-tag, .tile-accomp .tile-tag { color: var(--muted); }
      .tile-compta .tile-tag-dot, .tile-accomp .tile-tag-dot { background: var(--accent); }

      .tile-body { position: relative; z-index: 1; }
      .tile-name {
        font-size: clamp(1.1rem, 2vw, 1.4rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin-bottom: 10px;
      }
      .tile-desc {
        font-size: 0.875rem;
        line-height: 1.6;
      }
      /* Dark tile text */
      .tile-digital .tile-name { color: #fff; font-size: clamp(1.4rem, 2.5vw, 2rem); }
      .tile-digital .tile-desc { color: rgba(255,255,255,0.55); }
      /* Accent tile text */
      .tile-fiscal .tile-name { color: #fff; }
      .tile-fiscal .tile-desc { color: rgba(255,255,255,0.7); }
      /* Light tile text */
      .tile-compta .tile-name, .tile-accomp .tile-name { color: var(--text); }
      .tile-compta .tile-desc, .tile-accomp .tile-desc { color: var(--muted); }

      .tile-icon {
        width: 40px; height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
      }
      .tile-digital .tile-icon { background: rgba(43,95,232,0.25); }
      .tile-fiscal .tile-icon  { background: rgba(255,255,255,0.18); }
      .tile-compta .tile-icon, .tile-accomp .tile-icon { background: var(--accent-pale); }

      /* ─────────────────────────────────────────────────────
         POURQUOI — section sombre avec process timeline
      ───────────────────────────────────────────────────── */
      .pourquoi {
        position: relative;
        background: var(--dark-mid);
        padding: 112px 0;
        overflow: hidden;
        z-index: 10;
      }
      /* Blob radial subtil */
      .pourquoi::before {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 60vw; height: 60vw;
        max-width: 900px; max-height: 900px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(43,95,232,0.04) 0%, transparent 65%);
        pointer-events: none;
      }
      .pourquoi-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
        position: relative;
        z-index: 1;
      }
      /* Sticky left */
      .pourquoi-left {
        position: sticky;
        top: calc(var(--nav-h) + 40px);
        align-self: start;
      }
      .pourquoi-left .section-title {
        color: #fff;
        margin-bottom: 20px;
      }
      .pourquoi-left p {
        font-size: 1rem;
        color: rgba(255,255,255,0.45);
        line-height: 1.75;
        max-width: 40ch;
        margin-bottom: 16px;
      }

      /* Timeline steps — verticale avec bordure */
      .steps-list {
        padding-left: 56px;
        border-left: 1px solid var(--border-dark);
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .step {
        position: relative;
        padding-bottom: 52px;
      }
      .step:last-child { padding-bottom: 0; }
      .step-num-circle {
        position: absolute;
        left: -56px;
        top: 0;
        width: 40px; height: 40px;
        margin-left: -20px; /* center on border */
        border-radius: 50%;
        background: var(--dark-mid);
        border: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.35);
        font-feature-settings: 'tnum';
      }
      .step-title {
        font-size: clamp(1.1rem, 2vw, 1.375rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fff;
        margin-bottom: 10px;
        line-height: 1.2;
      }
      .step-text {
        font-size: 0.9375rem;
        color: rgba(255,255,255,0.45);
        line-height: 1.7;
        max-width: 44ch;
      }
      /* Step 2 décalé à droite (comme Floria) */
      .step:nth-child(2) { padding-left: 32px; }

      /* ─────────────────────────────────────────────────────
         CONTACT — fond clair, deux grandes actions
      ───────────────────────────────────────────────────── */
      .contact {
        background: var(--surface);
        padding: 112px 0;
        border-top: 1px solid var(--border);
      }
      .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }
      .contact-copy .section-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 16px;
      }
      .contact-copy .section-title { margin-bottom: 20px; }
      .contact-copy p {
        font-size: 1rem;
        color: var(--muted);
        line-height: 1.7;
        margin-bottom: 14px;
        max-width: 42ch;
      }
      .free-pill {
        display: inline-block;
        padding: 6px 16px;
        border-radius: var(--r-btn);
        background: var(--accent-pale);
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        margin-top: 8px;
      }

      /* Cartes contact cliquables */
      .contact-cards {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .contact-card {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 24px 28px;
        border-radius: var(--r-xl);
        border: 1.5px solid var(--border);
        background: var(--bg);
        transition: border-color 0.22s, box-shadow 0.22s, transform 0.22s;
        cursor: pointer;
      }
      .contact-card:hover {
        border-color: rgba(43,95,232,0.3);
        box-shadow: var(--shadow-md);
        transform: translateX(5px);
      }
      .contact-card:active { transform: translateX(2px) scale(0.995); }
      .contact-icon {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .icon-email { background: var(--accent-pale); }
      .icon-wa    { background: #E6F7EE; }
      .contact-label {
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 2px;
      }
      .contact-value {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text);
      }
      .contact-arrow {
        margin-left: auto;
        color: var(--muted);
        display: flex;
        transition: transform 0.2s ease;
        flex-shrink: 0;
      }
      .contact-card:hover .contact-arrow { transform: translateX(4px); }

      /* ─────────────────────────────────────────────────────
         FOOTER
      ───────────────────────────────────────────────────── */
      .footer {
        background: var(--dark);
        padding: 56px 0;
      }
      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 24px;
      }
      .footer-logo {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: #fff;
        margin-bottom: 6px;
      }
      .footer-logo span { color: var(--accent); }
      .footer-meta {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.3);
      }
      .footer-links {
        display: flex;
        gap: 28px;
        flex-wrap: wrap;
      }
      .footer-link {
        font-size: 0.875rem;
        color: rgba(255,255,255,0.45);
        transition: color 0.15s;
      }
      .footer-link:hover { color: #fff; }

