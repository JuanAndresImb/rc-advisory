    <script src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

    <script is:inline>
      window.addEventListener('load', function () {

        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var hasGsap = typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined';

        /* ── Nav dark/light (indépendant de GSAP) ── */
        var nav = document.getElementById('nav');
        var hero = document.getElementById('hero');
        if (nav && hero) {
          var sentinel = document.createElement('div');
          sentinel.style.cssText = 'position:absolute;top:' + (window.innerHeight - 1) + 'px;height:1px;width:100%;pointer-events:none;';
          hero.style.position = 'relative';
          hero.appendChild(sentinel);
          new IntersectionObserver(
            function (entries) { nav.classList.toggle('nav--light', !entries[0].isIntersecting); },
            { threshold: 0 }
          ).observe(sentinel);
        }

        /* ── Modale contact (email + WhatsApp) ── */
        var modal = document.getElementById('contact-modal');
        if (modal) {
          var lastFocus = null;
          var openModal = function () {
            lastFocus = document.activeElement;
            modal.classList.add('is-open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
            var first = modal.querySelector('.contact-card');
            if (first) { first.focus(); }
          };
          var closeModal = function () {
            modal.classList.remove('is-open');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            if (location.hash === '#contact-modal') {
              history.replaceState(null, '', location.pathname + location.search);
            }
            if (lastFocus && lastFocus.focus) { lastFocus.focus(); }
          };
          var openers = document.querySelectorAll('[data-modal-open]');
          for (var m = 0; m < openers.length; m++) {
            openers[m].addEventListener('click', function (e) { e.preventDefault(); openModal(); });
          }
          var closers = modal.querySelectorAll('[data-modal-close]');
          for (var n = 0; n < closers.length; n++) {
            closers[n].addEventListener('click', function (e) { e.preventDefault(); closeModal(); });
          }
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && modal.classList.contains('is-open')) { closeModal(); }
          });
          /* Une option choisie ferme la modale */
          var opts = modal.querySelectorAll('.contact-card');
          for (var o = 0; o < opts.length; o++) {
            opts[o].addEventListener('click', function () { setTimeout(closeModal, 60); });
          }
        }

        if (!hasGsap || reduceMotion) { return; }

        gsap.registerPlugin(ScrollTrigger);

        /* ── Lenis smooth scroll ── */
        var lenis = null;
        if (typeof Lenis !== 'undefined') {
          lenis = new Lenis({
            duration: 1.5,
            easing: function (t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); }
          });
          lenis.on('scroll', ScrollTrigger.update);
          gsap.ticker.add(function (time) { lenis.raf(time * 1000); });
          gsap.ticker.lagSmoothing(0);

          /* Ancres internes via Lenis (on ignore les déclencheurs de modale) */
          var anchors = document.querySelectorAll('a[href^="#"]');
          for (var i = 0; i < anchors.length; i++) {
            if (anchors[i].hasAttribute('data-modal-open') || anchors[i].hasAttribute('data-modal-close')) { continue; }
            anchors[i].addEventListener('click', function (e) {
              var href = this.getAttribute('href');
              if (href === '#' || href === '#contact-modal') { return; }
              var target = document.querySelector(href);
              if (target) {
                e.preventDefault();
                lenis.scrollTo(target, { offset: -72 });
              }
            });
          }
        }

        /* ── Hero entrance timeline ── */
        document.body.classList.add('js-anim');
        var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
        tl.fromTo('.hero-eyebrow',
            { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.7 })
          .fromTo('.hero-title .line',
            { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.8, stagger: 0.12 }, '-=0.4')
          .fromTo('.hero-sub',
            { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7 }, '-=0.5')
          .fromTo('.hero-ctas',
            { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.45')
          .fromTo('.hero-stats',
            { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.35');

        /* ── Parallax photo hero ── */
        gsap.to('#hero-photo', {
          yPercent: 18,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: true
          }
        });

        /* ── Fade-out du contenu hero au scroll ── */
        gsap.to('#hero-content', {
          opacity: 0,
          y: -40,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: '40% top',
            scrub: 0.8
          }
        });

        /* ── Bento cards : stagger reveal ── */
        gsap.from('.bento-tile', {
          opacity: 0,
          y: 50,
          duration: 0.8,
          ease: 'power3.out',
          stagger: 0.1,
          scrollTrigger: {
            trigger: '#bento',
            start: 'top 80%',
            toggleActions: 'play none none reverse'
          }
        });

        /* ── Fade-up génériques ── */
        var fadeEls = document.querySelectorAll('[data-anim="fade-up"]');
        for (var j = 0; j < fadeEls.length; j++) {
          gsap.from(fadeEls[j], {
            opacity: 0,
            y: 28,
            duration: 0.75,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: fadeEls[j],
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            }
          });
        }

        /* ── Timeline steps ── */
        var steps = document.querySelectorAll('.t-step');
        for (var k = 0; k < steps.length; k++) {
          gsap.from(steps[k], {
            opacity: 0,
            y: 28,
            duration: 0.7,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: steps[k],
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            }
          });
        }

        /* ── Photo déco pourquoi ── */
        gsap.from('.pourquoi-deco-photo', {
          opacity: 0,
          x: -60,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '#pourquoi',
            start: 'top 70%',
            toggleActions: 'play none none reverse'
          }
        });

        /* ── Split text closing : deux lignes qui s'écartent (desktop) ──
           Désactivé sous 768px : l'écart horizontal déborderait et
           décalerait le titre. */
        if (window.innerWidth >= 768) {
          gsap.fromTo('.closing-title .split-l',
            { x: 0 },
            {
              x: '-7vw',
              ease: 'none',
              scrollTrigger: {
                trigger: '#closing',
                start: 'top bottom',
                end: 'bottom top',
                scrub: 0.6
              }
            });
          gsap.fromTo('.closing-title .split-r',
            { x: 0 },
            {
              x: '7vw',
              ease: 'none',
              scrollTrigger: {
                trigger: '#closing',
                start: 'top bottom',
                end: 'bottom top',
                scrub: 0.6
              }
            });
        }

        /* Pas de parallax sur la photo closing : elle est cadrée pour
           être vue en entier, un déplacement révélerait ses bords. */

        ScrollTrigger.refresh();
      });
    </script>

  </body>
</html>
