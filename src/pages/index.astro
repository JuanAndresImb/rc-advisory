    <script src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

    <script is:inline>
      window.addEventListener('load', function () {

        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var hasGsap = typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined';

        /* ── Nav dark/light (indépendant de GSAP) ── */
        var nav = document.getElementById('nav');
        var hero = document.getElementById('hero');
        if (nav && hero) {
          var sentinel = document.createElement('div');
          sentinel.style.cssText = 'position:absolute;top:' + (window.innerHeight - 1) + 'px;height:1px;width:100%;pointer-events:none;';
          hero.style.position = 'relative';
          hero.appendChild(sentinel);
          new IntersectionObserver(
            function (entries) { nav.classList.toggle('nav--light', !entries[0].isIntersecting); },
            { threshold: 0 }
          ).observe(sentinel);
        }

        if (!hasGsap || reduceMotion) { return; }

        gsap.registerPlugin(ScrollTrigger);

        /* ── Lenis smooth scroll ── */
        var lenis = null;
        if (typeof Lenis !== 'undefined') {
          lenis = new Lenis({
            duration: 1.5,
            easing: function (t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)); }
          });
          lenis.on('scroll', ScrollTrigger.update);
          gsap.ticker.add(function (time) { lenis.raf(time * 1000); });
          gsap.ticker.lagSmoothing(0);

          /* Ancres internes via Lenis */
          var anchors = document.querySelectorAll('a[href^="#"]');
          for (var i = 0; i < anchors.length; i++) {
            anchors[i].addEventListener('click', function (e) {
              var target = document.querySelector(this.getAttribute('href'));
              if (target) {
                e.preventDefault();
                lenis.scrollTo(target, { offset: -72 });
              }
            });
          }
        }

        /* ── Hero entrance timeline ── */
        document.body.classList.add('js-anim');
        var tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
        tl.fromTo('.hero-eyebrow',
            { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.7 })
          .fromTo('.hero-title .line',
            { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.8, stagger: 0.12 }, '-=0.4')
          .fromTo('.hero-sub',
            { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.7 }, '-=0.5')
          .fromTo('.hero-ctas',
            { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.45')
          .fromTo('.hero-stats',
            { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.6 }, '-=0.35');

        /* ── Parallax photo hero ── */
        gsap.to('#hero-photo', {
          yPercent: 18,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: 'bottom top',
            scrub: true
          }
        });

        /* ── Fade-out du contenu hero au scroll ── */
        gsap.to('#hero-content', {
          opacity: 0,
          y: -40,
          ease: 'none',
          scrollTrigger: {
            trigger: '#hero',
            start: 'top top',
            end: '40% top',
            scrub: 0.8
          }
        });

        /* ── Bento cards : stagger reveal ── */
        gsap.from('.bento-tile', {
          opacity: 0,
          y: 50,
          duration: 0.8,
          ease: 'power3.out',
          stagger: 0.1,
          scrollTrigger: {
            trigger: '#bento',
            start: 'top 80%',
            toggleActions: 'play none none reverse'
          }
        });

        /* ── Fade-up génériques ── */
        var fadeEls = document.querySelectorAll('[data-anim="fade-up"]');
        for (var j = 0; j < fadeEls.length; j++) {
          gsap.from(fadeEls[j], {
            opacity: 0,
            y: 28,
            duration: 0.75,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: fadeEls[j],
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            }
          });
        }

        /* ── Timeline steps ── */
        var steps = document.querySelectorAll('.t-step');
        for (var k = 0; k < steps.length; k++) {
          gsap.from(steps[k], {
            opacity: 0,
            y: 28,
            duration: 0.7,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: steps[k],
              start: 'top 85%',
              toggleActions: 'play none none reverse'
            }
          });
        }

        /* ── Photo déco pourquoi ── */
        gsap.from('.pourquoi-deco-photo', {
          opacity: 0,
          x: -60,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '#pourquoi',
            start: 'top 70%',
            toggleActions: 'play none none reverse'
          }
        });

        /* ── Split text closing : deux lignes qui s'écartent ── */
        gsap.fromTo('.closing-title .split-l',
          { x: 0 },
          {
            x: '-7vw',
            ease: 'none',
            scrollTrigger: {
              trigger: '#closing',
              start: 'top bottom',
              end: 'bottom top',
              scrub: 0.6
            }
          });
        gsap.fromTo('.closing-title .split-r',
          { x: 0 },
          {
            x: '7vw',
            ease: 'none',
            scrollTrigger: {
              trigger: '#closing',
              start: 'top bottom',
              end: 'bottom top',
              scrub: 0.6
            }
          });

        /* ── Parallax photo closing ── */
        gsap.to('#closing-photo', {
          yPercent: 20,
          ease: 'none',
          scrollTrigger: {
            trigger: '#closing',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true
          }
        });

        ScrollTrigger.refresh();
      });
    </script>

  </body>
</html>
