---
// R&C Advisory — Page vitrine single-page v3
// Palette : forest green (remplace le bleu), photos Unsplash intégrées à la Floria
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="R&C Advisory — Expert-comptable 100% digital à Bruxelles. Comptabilité, conseil fiscal et accompagnement personnalisé pour indépendants et PME en Belgique." />
    <title>R&C Advisory — Expert-comptable digital à Bruxelles</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload des images critiques -->
    <link rel="preload" as="image" href="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=900&h=1100&q=80" />

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

      /* ── Tokens : forest green, fini le bleu ── */
      :root {
        --bg:           #F7F9F7;
        --surface:      #FFFFFF;
        --dark:         #070E08;        /* near-black, légèrement vert forêt */
        --dark-mid:     #0C1A0D;        /* vert forêt profond */
        --text:         #0F1A0F;
        --muted:        #6B7560;
        --accent:       #10B981;        /* emerald-500 */
        --accent-dk:    #059669;        /* emerald-600 */
        --accent-deep:  #064E3B;        /* emerald-900 */
        --accent-pale:  #ECFDF5;        /* emerald-50 */
        --border:       rgba(15,26,15,0.09);
        --border-dark:  rgba(255,255,255,0.08);
        --font:         'Outfit', system-ui, sans-serif;
        --max-w:        1280px;
        --nav-h:        72px;
        --r-xl:         24px;
        --r-2xl:        32px;
        --r-btn:        100px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }
      img { display: block; }

      .wrap {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 28px;
      }

      /* ────────────────────────────────────────────────
         NAV — transparent sur hero, clair ensuite
      ──────────────────────────────────────────────── */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        height: var(--nav-h);
        display: flex;
        align-items: center;
        background: transparent;
        border-bottom: 1px solid transparent;
        transition: background 0.4s ease, border-color 0.4s ease;
      }
      .nav.nav--light {
        background: rgba(247,249,247,0.92);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom-color: var(--border);
      }
      .nav .wrap {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav-logo {
        font-size: 1.1rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #fff;
        transition: color 0.4s ease;
      }
      .nav--light .nav-logo { color: var(--text); }
      .nav-logo span { color: var(--accent); }
      .btn-nav {
        padding: 10px 22px;
        border-radius: var(--r-btn);
        background: rgba(255,255,255,0.12);
        color: #fff;
        font-family: var(--font);
        font-size: 0.875rem;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,0.2);
        cursor: pointer;
        white-space: nowrap;
        backdrop-filter: blur(8px);
        transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.12s;
      }
      .nav--light .btn-nav {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        backdrop-filter: none;
      }
      .btn-nav:hover { opacity: 0.88; }
      .btn-nav:active { transform: scale(0.97); }

      /* ────────────────────────────────────────────────
         HERO — photo qui émerge de l'obscurité (Floria)
      ──────────────────────────────────────────────── */
      .hero {
        position: relative;
        min-height: 100dvh;
        background: var(--dark);
        display: flex;
        align-items: center;
        padding-top: var(--nav-h);
        overflow: hidden;
        z-index: 10;
      }

      /* Dot grid */
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(16,185,129,0.06) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }

      /* Photo portrait — droit, émerge du noir comme Floria */
      .hero-photo-wrap {
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        width: 52%;
        pointer-events: none;
        z-index: 1;
      }
      .hero-photo-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        filter: brightness(0.82) contrast(1.05);
      }
      /* Masque gradient : fondu vers le texte à gauche */
      .hero-photo-wrap::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to right,
          var(--dark) 0%,
          rgba(7,14,8,0.75) 30%,
          rgba(7,14,8,0.2) 60%,
          transparent 100%
        );
        z-index: 2;
      }
      /* Fondu bas */
      .hero-photo-wrap::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 35%;
        background: linear-gradient(to top, var(--dark), transparent);
        z-index: 2;
      }

      /* Fondue hero → section claire */
      .hero-bottom-fade {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 160px;
        background: linear-gradient(to top, var(--bg), transparent);
        pointer-events: none;
        z-index: 5;
      }

      .hero .wrap {
        position: relative;
        z-index: 10;
        padding-top: 72px;
        padding-bottom: 160px;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 14px;
        border-radius: var(--r-btn);
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.65);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        margin-bottom: 28px;
      }
      .eyebrow-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
      }

      .hero-title {
        font-size: clamp(3.25rem, 7.5vw, 6.5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 0.92;
        color: #fff;
        margin-bottom: 28px;
        max-width: 14ch;
      }
      .hero-title em {
        font-style: italic;
        font-weight: 300;
        color: rgba(255,255,255,0.4);
      }

      .hero-sub {
        font-size: clamp(1rem, 1.4vw, 1.125rem);
        color: rgba(255,255,255,0.5);
        line-height: 1.72;
        max-width: 40ch;
        margin-bottom: 40px;
      }

      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
      }
      .btn-hero-primary {
        padding: 15px 32px;
        border-radius: var(--r-btn);
        background: #fff;
        color: var(--dark);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.18s, transform 0.12s;
      }
      .btn-hero-primary:hover { background: rgba(255,255,255,0.92); }
      .btn-hero-primary:active { transform: scale(0.98); }

      .btn-hero-ghost {
        padding: 14px 28px;
        border-radius: var(--r-btn);
        background: transparent;
        color: rgba(255,255,255,0.65);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 500;
        border: 1px solid rgba(255,255,255,0.16);
        cursor: pointer;
        white-space: nowrap;
        transition: border-color 0.18s, color 0.18s, background 0.18s, transform 0.12s;
      }
      .btn-hero-ghost:hover {
        border-color: rgba(255,255,255,0.36);
        color: #fff;
        background: rgba(255,255,255,0.05);
      }
      .btn-hero-ghost:active { transform: scale(0.98); }

      /* Stats */
      .hero-stats {
        display: flex;
        gap: 48px;
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid rgba(255,255,255,0.07);
        flex-wrap: wrap;
      }
      .stat-num {
        font-size: 2.25rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: #fff;
        line-height: 1;
        margin-bottom: 5px;
      }
      .stat-num span { color: var(--accent); }
      .stat-label {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.38);
        line-height: 1.45;
        max-width: 16ch;
      }

      /* ── Reveal animations ── */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1),
                    transform 0.6s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal-scale {
        opacity: 0;
        transform: scale(0.95);
        transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1),
                    transform 0.65s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal-x {
        opacity: 0;
        transform: translateX(-28px);
        transition: opacity 0.6s cubic-bezier(0.16,1,0.3,1),
                    transform 0.6s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal.visible, .reveal-scale.visible, .reveal-x.visible {
        opacity: 1; transform: none;
      }
      .d1 { transition-delay: 0.07s; }
      .d2 { transition-delay: 0.14s; }
      .d3 { transition-delay: 0.21s; }
      .d4 { transition-delay: 0.28s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal, .reveal-scale, .reveal-x {
          opacity: 1; transform: none; transition: none;
        }
      }

      /* ────────────────────────────────────────────────
         SERVICES — bento photo + couleur (style Floria archives)
      ──────────────────────────────────────────────── */
      .services {
        position: relative;
        z-index: 20;
        background: var(--bg);
        padding: 100px 0 112px;
      }

      .services-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 40px;
        margin-bottom: 56px;
        flex-wrap: wrap;
      }
      .section-title {
        font-size: clamp(2rem, 3.8vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 1.08;
      }
      .services-desc {
        max-width: 38ch;
        color: var(--muted);
        font-size: 0.9375rem;
        line-height: 1.65;
      }

      /* Bento 4 tuiles asymétriques */
      .bento {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: 340px 260px;
        gap: 14px;
      }

      .bento-tile {
        position: relative;
        border-radius: var(--r-2xl);
        overflow: hidden;
        cursor: default;
        transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
      }
      .bento-tile:hover { transform: translateY(-5px); }

      /* Tile 1 : 100% Digital — IMAGE + overlay sombre vert */
      .tile-1 { grid-column: 1 / 8; grid-row: 1; }
      /* Tile 2 : Expertise-comptable — couleur vert profond */
      .tile-2 { grid-column: 8 / 13; grid-row: 1; background: var(--accent-deep); }
      /* Tile 3 : Conseil fiscal — accent emerald */
      .tile-3 { grid-column: 1 / 5; grid-row: 2; background: var(--accent); }
      /* Tile 4 : Accompagnement — IMAGE + overlay */
      .tile-4 { grid-column: 5 / 13; grid-row: 2; }

      /* Image de fond pour tiles photo */
      .tile-img {
        position: absolute;
        inset: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform 0.7s cubic-bezier(0.16,1,0.3,1);
        filter: brightness(0.7) saturate(0.9);
      }
      .bento-tile:hover .tile-img { transform: scale(1.06); }

      /* Overlay gradient sombre */
      .tile-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(7,14,8,0.80) 0%,
          rgba(7,14,8,0.30) 55%,
          transparent 100%
        );
        z-index: 1;
      }

      /* Contenu des tuiles */
      .tile-content {
        position: absolute;
        inset: 0;
        padding: 28px 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        z-index: 2;
      }

      .tile-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        align-self: flex-start;
      }
      .tile-1 .tile-tag, .tile-4 .tile-tag { color: rgba(255,255,255,0.55); }
      .tile-2 .tile-tag { color: rgba(255,255,255,0.4); }
      .tile-3 .tile-tag { color: rgba(255,255,255,0.65); }

      .tag-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .tile-1 .tag-dot, .tile-4 .tag-dot { background: var(--accent); }
      .tile-2 .tag-dot { background: rgba(255,255,255,0.3); }
      .tile-3 .tag-dot { background: rgba(255,255,255,0.7); }

      .tile-bottom {}
      .tile-name {
        font-size: clamp(1.1rem, 1.8vw, 1.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: #fff;
        margin-bottom: 8px;
        transform: translateY(4px);
        transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
      }
      .tile-2 .tile-name { font-size: clamp(1.1rem, 1.6vw, 1.35rem); }
      .bento-tile:hover .tile-name { transform: translateY(0); }

      .tile-desc {
        font-size: 0.875rem;
        line-height: 1.58;
        opacity: 0;
        transform: translateY(6px);
        transition: opacity 0.4s ease 0.07s, transform 0.4s ease 0.07s;
      }
      .bento-tile:hover .tile-desc { opacity: 1; transform: translateY(0); }
      .tile-1 .tile-desc, .tile-4 .tile-desc { color: rgba(255,255,255,0.65); }
      .tile-2 .tile-desc { color: rgba(255,255,255,0.55); }
      .tile-3 .tile-desc { color: rgba(255,255,255,0.75); }

      /* Filigrane décoratif sur tile-1 */
      .tile-1::after {
        content: '100%';
        position: absolute;
        right: -8px; bottom: -30px;
        font-size: clamp(100px, 14vw, 180px);
        font-weight: 800;
        letter-spacing: -0.06em;
        line-height: 1;
        color: rgba(16,185,129,0.1);
        pointer-events: none;
        user-select: none;
        z-index: 3;
      }

      /* ────────────────────────────────────────────────
         POURQUOI — dark forêt, photo déco gauche + timeline
      ──────────────────────────────────────────────── */
      .pourquoi {
        position: relative;
        background: var(--dark-mid);
        padding: 120px 0 120px;
        overflow: hidden;
        z-index: 10;
      }

      /* Photo architecturale décorative gauche (comme Floria) */
      .pourquoi-deco-photo {
        position: absolute;
        left: -80px;
        top: -60px;
        width: 42%;
        max-width: 600px;
        pointer-events: none;
        z-index: 0;
        -webkit-mask-image: radial-gradient(ellipse 80% 80% at 20% 50%, black 25%, transparent 75%);
        mask-image: radial-gradient(ellipse 80% 80% at 20% 50%, black 25%, transparent 75%);
        opacity: 0;
        transform: translateX(-60px);
        transition: opacity 0.9s ease 0.2s, transform 0.9s cubic-bezier(0.16,1,0.3,1) 0.2s;
      }
      .pourquoi-deco-photo.visible { opacity: 0.18; transform: translateX(0); }
      .pourquoi-deco-photo img {
        width: 100%;
        height: auto;
        object-fit: contain;
        mix-blend-mode: luminosity;
        filter: contrast(1.1);
      }

      /* Blob radial subtil */
      .pourquoi::before {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 70vw; height: 70vw;
        max-width: 1000px; max-height: 1000px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(16,185,129,0.04) 0%, transparent 60%);
        pointer-events: none;
        z-index: 0;
      }

      .pourquoi-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }

      .pourquoi-left {
        position: sticky;
        top: calc(var(--nav-h) + 40px);
        align-self: start;
      }
      .pourquoi-left .section-title {
        color: #fff;
        margin-bottom: 24px;
      }
      .pourquoi-left p {
        font-size: 1rem;
        color: rgba(255,255,255,0.42);
        line-height: 1.78;
        max-width: 40ch;
        margin-bottom: 18px;
      }

      /* Timeline numérotée */
      .timeline {
        border-left: 1px solid var(--border-dark);
        padding-left: 56px;
        display: flex;
        flex-direction: column;
      }
      .t-step {
        position: relative;
        padding-bottom: 56px;
      }
      .t-step:last-child { padding-bottom: 0; }
      .t-step:nth-child(2) { padding-left: 40px; }

      .t-num {
        position: absolute;
        left: -56px;
        top: 0;
        margin-left: -20px; /* centré sur la bordure */
        width: 40px; height: 40px;
        border-radius: 50%;
        background: var(--dark-mid);
        border: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.32);
        font-feature-settings: 'tnum';
      }
      .t-title {
        font-size: clamp(1.05rem, 1.8vw, 1.35rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fff;
        margin-bottom: 10px;
        line-height: 1.2;
      }
      .t-text {
        font-size: 0.9375rem;
        color: rgba(255,255,255,0.42);
        line-height: 1.72;
        max-width: 46ch;
      }

      /* ────────────────────────────────────────────────
         CONTACT
      ──────────────────────────────────────────────── */
      .contact {
        background: var(--surface);
        padding: 112px 0;
        border-top: 1px solid var(--border);
      }
      .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }
      .contact-section-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-dk);
        margin-bottom: 16px;
      }
      .contact-copy .section-title { margin-bottom: 20px; }
      .contact-copy p {
        font-size: 1rem;
        color: var(--muted);
        line-height: 1.72;
        max-width: 42ch;
        margin-bottom: 14px;
      }
      .free-pill {
        display: inline-block;
        padding: 6px 16px;
        border-radius: var(--r-btn);
        background: var(--accent-pale);
        color: var(--accent-dk);
        font-size: 0.8rem;
        font-weight: 700;
        margin-top: 8px;
      }

      .contact-cards {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .contact-card {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 22px 26px;
        border-radius: var(--r-xl);
        border: 1.5px solid var(--border);
        background: var(--bg);
        transition: border-color 0.22s, box-shadow 0.22s, transform 0.22s;
        cursor: pointer;
      }
      .contact-card:hover {
        border-color: rgba(16,185,129,0.35);
        box-shadow: 0 4px 20px rgba(16,185,129,0.08), 0 12px 40px rgba(0,0,0,0.06);
        transform: translateX(5px);
      }
      .contact-card:active { transform: translateX(2px) scale(0.995); }
      .c-icon {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .c-icon-email { background: var(--accent-pale); }
      .c-icon-wa    { background: #DCFCE7; }
      .c-label {
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 2px;
      }
      .c-value {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text);
      }
      .c-caret {
        margin-left: auto;
        color: var(--muted);
        display: flex;
        transition: transform 0.2s ease;
        flex-shrink: 0;
      }
      .contact-card:hover .c-caret { transform: translateX(4px); }

      /* ────────────────────────────────────────────────
         FOOTER
      ──────────────────────────────────────────────── */
      .footer {
        background: var(--dark);
        padding: 56px 0;
      }
      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 24px;
      }
      .footer-logo {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        color: #fff;
        margin-bottom: 5px;
      }
      .footer-logo span { color: var(--accent); }
      .footer-meta { font-size: 0.8rem; color: rgba(255,255,255,0.28); }
      .footer-links { display: flex; gap: 28px; flex-wrap: wrap; }
