---
// R&C Advisory — Page vitrine single-page v5
// Palette orange/ambre (logo), Fraunces + Plus Jakarta Sans,
// Lenis smooth scroll + GSAP/ScrollTrigger, closing dark fusionné au footer
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="R&C Advisory — Expert-comptable 100% digital à Bruxelles. Comptabilité, fiscalité et accompagnement personnalisé pour indépendants et PME en Belgique." />
    <title>R&C Advisory — Expert-comptable digital à Bruxelles</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preload" as="image" href="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=900&h=1100&q=80" />

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..800;1,9..144,300..800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

      /* ── Tokens : palette orange/ambre du logo ── */
      :root {
        --bg:           #F8F6F2;
        --surface:      #FFFFFF;
        --dark:         #0E0B07;
        --dark-mid:     #160F08;
        --text:         #1A1108;
        --muted:        #6B6257;
        --accent:       #F0821C;
        --accent-dk:    #C66A0F;
        --accent-deep:  #1F0F04;
        --accent-pale:  #FEF0E0;
        --border:       rgba(26,17,8,0.09);
        --border-dark:  rgba(255,255,255,0.08);
        --font:         'Plus Jakarta Sans', system-ui, sans-serif;
        --font-display: 'Fraunces', Georgia, serif;
        --max-w:        1280px;
        --nav-h:        72px;
        --r-xl:         24px;
        --r-2xl:        32px;
        --r-btn:        100px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html.lenis, html.lenis body { height: auto; }
      .lenis.lenis-smooth { scroll-behavior: auto !important; }
      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }
      img { display: block; }

      .wrap {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 28px;
      }

      /* ────────────────────────────────────────────────
         NAV
      ──────────────────────────────────────────────── */
      .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
        height: var(--nav-h);
        display: flex;
        align-items: center;
        background: transparent;
        border-bottom: 1px solid transparent;
        transition: background 0.4s ease, border-color 0.4s ease;
      }
      .nav.nav--light {
        background: rgba(248,246,242,0.94);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom-color: var(--border);
      }
      .nav .wrap {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-logo-img {
        height: 40px;
        width: auto;
        filter: brightness(0) invert(1);
        transition: filter 0.4s ease;
      }
      .nav--light .nav-logo-img { filter: none; }

      .btn-nav {
        padding: 10px 22px;
        border-radius: var(--r-btn);
        background: rgba(255,255,255,0.12);
        color: #fff;
        font-family: var(--font);
        font-size: 0.875rem;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,0.2);
        cursor: pointer;
        white-space: nowrap;
        backdrop-filter: blur(8px);
        transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.12s;
      }
      .nav--light .btn-nav {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        backdrop-filter: none;
      }
      .btn-nav:hover { opacity: 0.88; }
      .btn-nav:active { transform: scale(0.97); }

      /* ────────────────────────────────────────────────
         HERO
      ──────────────────────────────────────────────── */
      .hero {
        position: relative;
        min-height: 100dvh;
        background: var(--dark);
        display: flex;
        align-items: center;
        padding-top: var(--nav-h);
        overflow: hidden;
        z-index: 10;
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(240,130,28,0.055) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }

      .hero-photo-wrap {
        position: absolute;
        top: -8%; right: 0;
        height: 116%;   /* marge pour le parallax */
        width: 52%;
        pointer-events: none;
        z-index: 1;
      }
      .hero-photo-wrap img {
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center top;
        filter: brightness(0.82) contrast(1.05);
      }
      .hero-photo-wrap::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(
          to right,
          var(--dark) 0%,
          rgba(14,11,7,0.75) 30%,
          rgba(14,11,7,0.2) 60%,
          transparent 100%
        );
        z-index: 2;
      }
      .hero-photo-wrap::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 35%;
        background: linear-gradient(to top, var(--dark), transparent);
        z-index: 2;
      }

      .hero-bottom-fade {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 160px;
        background: linear-gradient(to top, var(--bg), transparent);
        pointer-events: none;
        z-index: 5;
      }

      .hero .wrap {
        position: relative;
        z-index: 10;
        padding-top: 72px;
        padding-bottom: 160px;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 14px;
        border-radius: var(--r-btn);
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.06);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.65);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        margin-bottom: 28px;
      }
      .eyebrow-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
      }

      .hero-title {
        font-family: var(--font-display);
        font-size: clamp(3rem, 7vw, 6rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 0.98;
        color: #fff;
        margin-bottom: 28px;
        max-width: 14ch;
      }
      .hero-title .line { display: block; }
      .hero-title em {
        font-style: italic;
        font-weight: 300;
        color: rgba(255,255,255,0.45);
      }

      .hero-sub {
        font-size: clamp(0.95rem, 1.3vw, 1.05rem);
        color: rgba(255,255,255,0.48);
        line-height: 1.76;
        max-width: 46ch;
        margin-bottom: 40px;
      }

      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
      }
      .btn-hero-primary {
        padding: 15px 32px;
        border-radius: var(--r-btn);
        background: #fff;
        color: var(--dark);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: background 0.18s, transform 0.12s;
      }
      .btn-hero-primary:hover { background: rgba(255,255,255,0.92); }
      .btn-hero-primary:active { transform: scale(0.98); }

      .btn-hero-ghost {
        padding: 14px 28px;
        border-radius: var(--r-btn);
        background: transparent;
        color: rgba(255,255,255,0.65);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 500;
        border: 1px solid rgba(255,255,255,0.16);
        cursor: pointer;
        transition: border-color 0.18s, color 0.18s, background 0.18s, transform 0.12s;
      }
      .btn-hero-ghost:hover {
        border-color: rgba(255,255,255,0.36);
        color: #fff;
        background: rgba(255,255,255,0.05);
      }
      .btn-hero-ghost:active { transform: scale(0.98); }

      .hero-stats {
        display: flex;
        gap: 48px;
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid rgba(255,255,255,0.07);
        flex-wrap: wrap;
      }
      .stat-num {
        font-family: var(--font-display);
        font-size: 2.25rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: #fff;
        line-height: 1;
        margin-bottom: 5px;
      }
      .stat-num span { color: var(--accent); }
      .stat-label {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.38);
        line-height: 1.45;
        max-width: 16ch;
      }
      .stat-badge {
        font-family: var(--font-display);
        font-style: italic;
        font-size: 1.35rem;
        font-weight: 500;
        letter-spacing: -0.01em;
        color: var(--accent);
        line-height: 1;
        margin-bottom: 8px;
      }

      /* Éléments animés par GSAP : état initial via .anim (JS ajoute la classe au body) */
      .js-anim .hero-eyebrow,
      .js-anim .hero-title .line,
      .js-anim .hero-sub,
      .js-anim .hero-ctas,
      .js-anim .hero-stats { opacity: 0; }

      /* ────────────────────────────────────────────────
         SERVICES — bento 4 tuiles
      ──────────────────────────────────────────────── */
      .services {
        position: relative;
        z-index: 20;
        background: var(--bg);
        padding: 100px 0 112px;
      }

      .services-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 40px;
        margin-bottom: 56px;
        flex-wrap: wrap;
      }
      .section-title {
        font-family: var(--font-display);
        font-size: clamp(1.9rem, 3.6vw, 2.9rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.08;
      }
      .section-title em {
        font-style: italic;
        font-weight: 400;
        color: var(--accent-dk);
      }
      .services-desc {
        max-width: 38ch;
        color: var(--muted);
        font-size: 0.9375rem;
        line-height: 1.65;
      }

      .bento {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: 340px 260px;
        gap: 14px;
      }

      .bento-tile {
        position: relative;
        border-radius: var(--r-2xl);
        overflow: hidden;
        cursor: default;
        transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
      }
      .bento-tile:hover { transform: translateY(-5px); }

      .tile-1 { grid-column: 1 / 8; grid-row: 1; }
      .tile-2 { grid-column: 8 / 13; grid-row: 1; background: var(--accent-deep); }
      .tile-3 { grid-column: 1 / 5; grid-row: 2; background: #B5540A; }
      .tile-4 { grid-column: 5 / 13; grid-row: 2; }

      .tile-img {
        position: absolute; inset: 0;
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform 0.7s cubic-bezier(0.16,1,0.3,1);
        filter: brightness(0.7) saturate(0.9);
      }
      .bento-tile:hover .tile-img { transform: scale(1.06); }

      .tile-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(14,11,7,0.82) 0%, rgba(14,11,7,0.32) 55%, transparent 100%);
        z-index: 1;
      }

      .tile-content {
        position: absolute; inset: 0;
        padding: 28px 32px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        z-index: 2;
      }

      .tile-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        align-self: flex-start;
      }
      .tile-1 .tile-tag, .tile-4 .tile-tag { color: rgba(255,255,255,0.55); }
      .tile-2 .tile-tag { color: rgba(255,255,255,0.4); }
      .tile-3 .tile-tag { color: rgba(255,255,255,0.65); }

      .tag-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .tile-1 .tag-dot, .tile-4 .tag-dot { background: var(--accent); }
      .tile-2 .tag-dot { background: rgba(255,255,255,0.3); }
      .tile-3 .tag-dot { background: rgba(255,255,255,0.7); }

      .tile-name {
        font-size: clamp(1.1rem, 1.8vw, 1.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: #fff;
        margin-bottom: 8px;
        transform: translateY(4px);
        transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
      }
      .tile-2 .tile-name { font-size: clamp(1.1rem, 1.6vw, 1.35rem); }
      .bento-tile:hover .tile-name { transform: translateY(0); }

      .tile-desc {
        font-size: 0.875rem;
        line-height: 1.58;
        opacity: 0;
        transform: translateY(6px);
        transition: opacity 0.4s ease 0.07s, transform 0.4s ease 0.07s;
      }
      .bento-tile:hover .tile-desc { opacity: 1; transform: translateY(0); }
      .tile-1 .tile-desc, .tile-4 .tile-desc { color: rgba(255,255,255,0.65); }
      .tile-2 .tile-desc { color: rgba(255,255,255,0.55); }
      .tile-3 .tile-desc { color: rgba(255,255,255,0.75); }

      .tile-1::after {
        content: '100%';
        position: absolute;
        right: -8px; bottom: -30px;
        font-family: var(--font-display);
        font-size: clamp(100px, 14vw, 180px);
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 1;
        color: rgba(240,130,28,0.12);
        pointer-events: none;
        user-select: none;
        z-index: 3;
      }

      /* ────────────────────────────────────────────────
         POURQUOI — dark ambre, photo déco + timeline 4 étapes
      ──────────────────────────────────────────────── */
      .pourquoi {
        position: relative;
        background: var(--dark-mid);
        padding: 120px 0;
        overflow: hidden;
        z-index: 10;
      }

      .pourquoi-deco-photo {
        position: absolute;
        left: -80px; top: -60px;
        width: 42%; max-width: 600px;
        pointer-events: none;
        z-index: 0;
        -webkit-mask-image: radial-gradient(ellipse 80% 80% at 20% 50%, black 25%, transparent 75%);
        mask-image: radial-gradient(ellipse 80% 80% at 20% 50%, black 25%, transparent 75%);
        opacity: 0.18;
      }
      .pourquoi-deco-photo img {
        width: 100%; height: auto;
        mix-blend-mode: luminosity;
        filter: contrast(1.1);
      }

      .pourquoi::before {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 70vw; height: 70vw;
        max-width: 1000px; max-height: 1000px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(240,130,28,0.05) 0%, transparent 60%);
        pointer-events: none;
        z-index: 0;
      }

      .pourquoi-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }

      .pourquoi-left {
        position: sticky;
        top: calc(var(--nav-h) + 40px);
        align-self: start;
      }
      .pourquoi-left .section-title {
        color: #fff;
        margin-bottom: 24px;
      }
      .pourquoi-left .section-title em { color: var(--accent); }
      .pourquoi-left p {
        font-size: 1rem;
        color: rgba(255,255,255,0.42);
        line-height: 1.78;
        max-width: 40ch;
        margin-bottom: 18px;
      }

      .timeline {
        border-left: 1px solid var(--border-dark);
        padding-left: 56px;
        display: flex;
        flex-direction: column;
      }
      .t-step {
        position: relative;
        padding-bottom: 52px;
      }
      .t-step:last-child { padding-bottom: 0; }
      .t-step:nth-child(2) { padding-left: 40px; }

      .t-num {
        position: absolute;
        left: -56px; top: 0;
        margin-left: -20px;
        width: 40px; height: 40px;
        border-radius: 50%;
        background: var(--dark-mid);
        border: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.32);
        font-feature-settings: 'tnum';
      }
      .t-title {
        font-size: clamp(1rem, 1.8vw, 1.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fff;
        margin-bottom: 10px;
        line-height: 1.2;
      }
      .t-text {
        font-size: 0.9375rem;
        color: rgba(255,255,255,0.42);
        line-height: 1.72;
        max-width: 46ch;
      }

      /* ────────────────────────────────────────────────
         CONTACT
      ──────────────────────────────────────────────── */
      .contact {
        background: var(--surface);
        padding: 112px 0;
        border-top: 1px solid var(--border);
      }
      .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }
      .contact-section-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-dk);
        margin-bottom: 16px;
      }
      .contact-copy .section-title { margin-bottom: 20px; }
      .contact-copy p {
        font-size: 1rem;
        color: var(--muted);
        line-height: 1.72;
        max-width: 44ch;
        margin-bottom: 14px;
      }
      .free-pill {
        display: inline-block;
        padding: 6px 16px;
        border-radius: var(--r-btn);
        background: var(--accent-pale);
        color: var(--accent-dk);
        font-size: 0.8rem;
        font-weight: 700;
        margin-top: 8px;
      }

      .contact-cards {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .contact-card {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 22px 26px;
        border-radius: var(--r-xl);
        border: 1.5px solid var(--border);
        background: var(--bg);
        transition: border-color 0.22s, box-shadow 0.22s, transform 0.22s;
        cursor: pointer;
      }
      .contact-card:hover {
        border-color: rgba(240,130,28,0.38);
        box-shadow: 0 4px 20px rgba(240,130,28,0.09), 0 12px 40px rgba(0,0,0,0.05);
        transform: translateX(5px);
      }
      .contact-card:active { transform: translateX(2px) scale(0.995); }
      .c-icon {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .c-icon-email { background: var(--accent-pale); }
      .c-icon-wa    { background: #DCFCE7; }
      .c-label {
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 2px;
      }
      .c-value {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text);
      }
      .c-caret {
        margin-left: auto;
        color: var(--muted);
        display: flex;
        transition: transform 0.2s ease;
        flex-shrink: 0;
      }
      .contact-card:hover .c-caret { transform: translateX(4px); }

      /* ────────────────────────────────────────────────
         CLOSING — dark, photo émotionnelle, fusion footer
      ──────────────────────────────────────────────── */
      .closing {
        position: relative;
        background: var(--dark);
        min-height: 88vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        text-align: center;
      }
      .closing-photo {
        position: absolute;
        top: -10%; left: 0;
        width: 100%; height: 120%;   /* marge pour le parallax */
        pointer-events: none;
        z-index: 0;
      }
      .closing-photo img {
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: center 30%;
        filter: brightness(0.4) saturate(0.85);
      }
      /* Dégradé bottom-only : fusion avec le footer */
      .closing-photo::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 45%;
        background: linear-gradient(to top, var(--dark), transparent);
      }

      .closing-content {
        position: relative;
        z-index: 2;
        padding: 140px 28px;
        max-width: 800px;
      }
      .closing-title {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 5rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.04;
        color: #fff;
        margin-bottom: 28px;
      }
      .closing-title .split-l, .closing-title .split-r { display: block; }
      .closing-title em {
        font-style: italic;
        font-weight: 300;
        color: var(--accent);
      }
      .closing-sub {
        font-size: clamp(0.95rem, 1.3vw, 1.1rem);
        color: rgba(255,255,255,0.55);
        line-height: 1.7;
        max-width: 46ch;
        margin: 0 auto 40px;
      }
      .btn-closing {
        display: inline-block;
        padding: 17px 40px;
        border-radius: var(--r-btn);
        background: var(--accent);
        color: #fff;
        font-family: var(--font);
        font-size: 1rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: background 0.18s, transform 0.12s;
