---
// R&C Advisory — Page vitrine single-page
// Astro minimal, CSS vanilla, mobile-first, Intersection Observer pour les animations
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="R&C Advisory — Expert-comptable 100% digital à Bruxelles. Comptabilité, conseil fiscal et accompagnement personnalisé pour indépendants et PME en Belgique." />
    <title>R&C Advisory — Expert-comptable digital à Bruxelles</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <style>
      /* ─── Fonts ──────────────────────────────────────────── */
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

      /* ─── Tokens ─────────────────────────────────────────── */
      :root {
        --bg:          #F7F8FA;
        --bg-alt:      #ECEEF2;
        --surface:     #FFFFFF;
        --text:        #0F1419;
        --text-muted:  #5A6473;
        --accent:      #2B5FE8;
        --accent-dark: #1E47C8;
        --accent-pale: #EEF2FE;
        --border:      rgba(15,20,25,0.10);
        --radius-card: 16px;
        --radius-btn:  100px;
        --shadow-card: 0 1px 3px rgba(15,20,25,0.07), 0 8px 24px rgba(15,20,25,0.06);
        --font:        'Outfit', system-ui, sans-serif;
        --max-w:       1240px;
        --nav-h:       68px;
      }

      /* ─── Reset & Base ───────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }

      /* ─── Container ──────────────────────────────────────── */
      .wrap {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ─── Navigation ─────────────────────────────────────── */
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        height: var(--nav-h);
        background: rgba(247,248,250,0.88);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
      }
      .nav .wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
      }
      .nav-logo {
        font-size: 1.125rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text);
      }
      .nav-logo span {
        color: var(--accent);
      }
      .btn-nav {
        display: inline-flex;
        align-items: center;
        padding: 10px 22px;
        border-radius: var(--radius-btn);
        background: var(--accent);
        color: #fff;
        font-family: var(--font);
        font-size: 0.875rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.18s ease, transform 0.12s ease;
      }
      .btn-nav:hover { background: var(--accent-dark); }
      .btn-nav:active { transform: scale(0.98); }

      /* ─── Hero ───────────────────────────────────────────── */
      .hero {
        min-height: 100dvh;
        padding-top: var(--nav-h);
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }
      .hero-bg::before {
        content: '';
        position: absolute;
        right: -8%;
        top: 12%;
        width: min(580px, 60vw);
        height: min(580px, 60vw);
        border-radius: 50%;
        background: radial-gradient(ellipse at 40% 40%, var(--accent-pale) 0%, transparent 70%);
        opacity: 0.8;
      }
      .hero-bg::after {
        content: '';
        position: absolute;
        right: 8%;
        top: 20%;
        width: min(320px, 35vw);
        height: min(320px, 35vw);
        border-radius: 50%;
        background: radial-gradient(ellipse at 60% 60%, rgba(43,95,232,0.09) 0%, transparent 70%);
      }

      /* Grille décorative desktop uniquement */
      .hero-grid-art {
        position: absolute;
        right: 5%;
        top: 50%;
        transform: translateY(-50%);
        display: none;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.6s ease 0.4s;
      }
      .hero-grid-art.visible { opacity: 1; }
      .hero-grid-art .tile {
        width: clamp(72px, 8vw, 100px);
        height: clamp(72px, 8vw, 100px);
        border-radius: 14px;
        border: 1.5px solid var(--border);
        background: var(--surface);
        box-shadow: var(--shadow-card);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: clamp(0.6rem, 1vw, 0.78rem);
        color: var(--text-muted);
        text-align: center;
        padding: 10px;
        line-height: 1.3;
        transition: transform 0.3s ease;
      }
      .hero-grid-art .tile.accent-tile {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        font-size: clamp(0.7rem, 1.2vw, 0.9rem);
      }
      .hero-grid-art .tile.tall {
        grid-row: span 2;
        height: auto;
        min-height: clamp(156px, 17.5vw, 212px);
        flex-direction: column;
        gap: 4px;
      }
      .hero-grid-art .tile-big-num {
        font-size: clamp(1.5rem, 2.5vw, 2rem);
        font-weight: 800;
        line-height: 1;
      }
      .hero-grid-art .tile:hover { transform: translateY(-3px); }

      .hero .wrap {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr;
        gap: 48px;
        padding-top: 64px;
        padding-bottom: 80px;
      }
      .hero-content { max-width: 600px; }
      .hero-tag {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 20px;
      }
      .hero-title {
        font-size: clamp(2.25rem, 5.5vw, 3.75rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.025em;
        color: var(--text);
        margin-bottom: 22px;
      }
      .hero-title em {
        font-style: normal;
        color: var(--accent);
      }
      .hero-sub {
        font-size: 1.0625rem;
        color: var(--text-muted);
        line-height: 1.65;
        max-width: 480px;
        margin-bottom: 36px;
      }
      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
      }
      .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 14px 28px;
        border-radius: var(--radius-btn);
        background: var(--accent);
        color: #fff;
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.18s ease, transform 0.12s ease, box-shadow 0.18s ease;
        box-shadow: 0 4px 16px rgba(43,95,232,0.25);
      }
      .btn-primary:hover {
        background: var(--accent-dark);
        box-shadow: 0 6px 20px rgba(43,95,232,0.32);
      }
      .btn-primary:active { transform: scale(0.98); }
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        padding: 13px 24px;
        border-radius: var(--radius-btn);
        background: transparent;
        color: var(--text);
        font-family: var(--font);
        font-size: 0.9375rem;
        font-weight: 500;
        border: 1.5px solid var(--border);
        cursor: pointer;
        white-space: nowrap;
        transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, transform 0.12s ease;
      }
      .btn-secondary:hover {
        border-color: var(--accent);
        background: var(--accent-pale);
        color: var(--accent);
      }
      .btn-secondary:active { transform: scale(0.98); }

      /* ─── Reveal animation (Intersection Observer) ───────── */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 { transition-delay: 0.08s; }
      .reveal-delay-2 { transition-delay: 0.16s; }
      .reveal-delay-3 { transition-delay: 0.24s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        .hero-grid-art { opacity: 1 !important; transition: none; }
        * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
      }

      /* ─── Section commons ────────────────────────────────── */
      section { padding: 96px 0; }
      .section-label {
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 14px;
      }
      .section-title {
        font-size: clamp(1.75rem, 3.5vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin-bottom: 16px;
      }

      /* ─── Services ───────────────────────────────────────── */
      .services { background: var(--surface); }
      .services-header {
        max-width: 540px;
        margin-bottom: 52px;
      }
      .services-header p {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.65;
      }
      .services-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
      }
      .service-card {
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-card);
        padding: 32px;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
      }
      .service-card:hover {
        border-color: rgba(43,95,232,0.28);
        box-shadow: var(--shadow-card);
        transform: translateY(-2px);
      }
      /* Carte 100% digital : occupe toute la colonne gauche */
      .service-card.featured {
        background: var(--accent);
        border-color: var(--accent);
        grid-column: 1;
        grid-row: 1 / span 2;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 320px;
      }
      .service-card.featured:hover {
        border-color: var(--accent-dark);
        box-shadow: 0 8px 32px rgba(43,95,232,0.25);
      }
      .service-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--accent-pale);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        flex-shrink: 0;
      }
      .service-card.featured .service-icon {
        background: rgba(255,255,255,0.18);
      }
      .service-name {
        font-size: 1.0625rem;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: -0.01em;
      }
      .service-card.featured .service-name {
        color: #fff;
        font-size: 1.25rem;
      }
      .service-desc {
        font-size: 0.9375rem;
        color: var(--text-muted);
        line-height: 1.6;
      }
      .service-card.featured .service-desc {
        color: rgba(255,255,255,0.75);
      }
      .service-badge {
        display: inline-block;
        margin-top: 28px;
        padding: 6px 14px;
        border-radius: 100px;
        background: rgba(255,255,255,0.18);
        color: rgba(255,255,255,0.88);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        align-self: flex-start;
      }

      /* ─── Pourquoi ───────────────────────────────────────── */
      .why { background: var(--bg); }
      .why-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
      }
      .why-left .section-title { margin-bottom: 20px; }
      .why-left p {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.7;
        margin-bottom: 18px;
      }
      .why-right {
        display: flex;
        flex-direction: column;
        gap: 0;
        border-left: 2px solid var(--border);
        padding-left: 48px;
      }
      .why-point {
        padding: 28px 0;
        border-bottom: 1px solid var(--border);
      }
      .why-point:first-child { padding-top: 0; }
      .why-point:last-child { border-bottom: none; padding-bottom: 0; }
      .why-point-num {
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.12em;
        margin-bottom: 10px;
        font-feature-settings: 'tnum';
      }
      .why-point-title {
        font-size: 1.0625rem;
        font-weight: 700;
        margin-bottom: 8px;
        letter-spacing: -0.01em;
      }
      .why-point-text {
        font-size: 0.9375rem;
        color: var(--text-muted);
        line-height: 1.65;
      }

      /* ─── Contact ────────────────────────────────────────── */
      .contact {
        background: var(--surface);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
      }
      .contact-copy .section-title { margin-bottom: 16px; }
      .contact-copy p {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1.7;
        margin-bottom: 14px;
      }
      .free-tag {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 100px;
        background: var(--accent-pale);
        color: var(--accent);
        font-size: 0.8125rem;
        font-weight: 600;
        margin-top: 6px;
      }
      .contact-actions {
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .contact-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        border-radius: var(--radius-card);
        border: 1.5px solid var(--border);
        background: var(--bg);
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
        cursor: pointer;
      }
      .contact-card:hover {
        border-color: rgba(43,95,232,0.28);
        box-shadow: var(--shadow-card);
        transform: translateX(4px);
      }
      .contact-card:active { transform: scale(0.99); }
      .contact-card-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .email-icon { background: var(--accent-pale); }
      .wa-icon { background: #E8F8EE; }
      .contact-card-label {
        font-size: 0.79rem;
        color: var(--text-muted);
        margin-bottom: 2px;
      }
      .contact-card-value {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
      }
      .contact-card-caret {
        margin-left: auto;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        transition: transform 0.2s ease;
        flex-shrink: 0;
      }
      .contact-card:hover .contact-card-caret { transform: translateX(3px); }

      /* ─── Footer ─────────────────────────────────────────── */
      .footer {
        background: var(--text);
        color: rgba(255,255,255,0.55);
        padding: 44px 0;
      }
      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
      }
      .footer-logo {
        font-size: 1.0625rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 5px;
      }
      .footer-logo span { color: rgba(43,95,232,0.85); }
      .footer-meta {
        font-size: 0.8125rem;
        color: rgba(255,255,255,0.38);
      }
      .footer-links {
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
      }
      .footer-link {
        font-size: 0.875rem;
        color: rgba(255,255,255,0.5);
        transition: color 0.15s ease;
      }
      .footer-link:hover { color: #fff; }

      /* ─── Responsive mobile-first ────────────────────────── */
      @media (max-width: 767px) {
        section { padding: 64px 0; }
        .wrap { padding: 0 20px; }

        .hero .wrap {
          padding-top: 36px;
          padding-bottom: 56px;
          gap: 0;
        }

        .services-grid {
          grid-template-columns: 1fr;
          gap: 14px;
        }
        .service-card.featured {
          grid-column: auto;
          grid-row: auto;
          min-height: auto;
        }

        .why-inner {
          grid-template-columns: 1fr;
          gap: 36px;
        }
        .why-right {
          border-left: none;
          padding-left: 0;
          border-top: 2px solid var(--border);
          padding-top: 8px;
        }
        .why-point:first-child { padding-top: 20px; }

        .contact-inner {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .footer-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 24px;
        }

        .hero-ctas { flex-direction: column; align-items: stretch; }
        .btn-primary, .btn-secondary { justify-content: center; width: 100%; }
      }

      @media (min-width: 768px) and (max-width: 1023px) {
        .services-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
        .service-card.featured {
          grid-column: 1 / span 2;
          grid-row: auto;
          min-height: auto;
          flex-direction: row;
          align-items: center;
          gap: 32px;
        }
        .service-card.featured .service-badge { margin-top: 0; }
        .why-inner { gap: 48px; }
        .contact-inner { gap: 48px; }
      }

      @media (min-width: 1024px) {
        .hero .wrap {
          grid-template-columns: 1fr 1fr;
          align-items: center;
          padding-top: 80px;
          padding-bottom: 80px;
        }
        .hero-grid-art { display: grid; }
      }
    </style>
  </head>

  <body>

    <!-- Navigation ────────────────────────────────────────── -->
    <nav class="nav" role="navigation" aria-label="Navigation principale">
      <div class="wrap">
        <div class="nav-logo">R<span>&amp;</span>C Advisory</div>
        <a
          href="#contact"
          class="btn-nav"
        >
          Prendre rendez-vous
        </a>
      </div>
    </nav>


    <!-- Hero ──────────────────────────────────────────────── -->
    <section class="hero" id="accueil" aria-labelledby="hero-title">
      <div class="hero-bg" aria-hidden="true"></div>

      <!-- Grille décorative — desktop seulement, zéro image placeholder -->
      <div class="hero-grid-art" aria-hidden="true">
        <div class="tile accent-tile tall">
          <span class="tile-big-num">100%</span>
          <span>Digital</span>
        </div>
        <div class="tile">TVA<br>IPP</div>
        <div class="tile">ISOC</div>
        <div class="tile">Bilan<br>annuel</div>
        <div class="tile">Conseil<br>fiscal</div>
      </div>

      <div class="wrap">
        <div class="hero-content">
          <div class="hero-tag reveal">Expert-comptable · Bruxelles</div>
          <h1 class="hero-title reveal reveal-delay-1" id="hero-title">
            La comptabilité,<br>sans <em>la paperasse</em>.
          </h1>
          <p class="hero-sub reveal reveal-delay-2">
            R&amp;C Advisory gère vos comptes entièrement à distance. Pas de déplacement, pas de classeur en carton. Un interlocuteur disponible qui connaît votre dossier.
          </p>
          <div class="hero-ctas reveal reveal-delay-3">
            <a href="#contact" class="btn-primary">Prendre rendez-vous</a>
            <a href="#services" class="btn-secondary">Voir les services</a>
          </div>
        </div>
      </div>
    </section>


    <!-- Services ──────────────────────────────────────────── -->
    <section class="services" id="services" aria-labelledby="services-title">
      <div class="wrap">
        <header class="services-header">
          <h2 class="section-title reveal" id="services-title">
            Quatre services,<br>un seul contact.
          </h2>
          <p class="reveal reveal-delay-1">
            Pas de renvoi entre services, pas de temps perdu à réexpliquer votre situation. Ricardo suit votre dossier de A à Z.
          </p>
        </header>

        <div class="services-grid">

          <!-- Carte principale : 100% digital -->
          <div class="service-card featured reveal">
            <div>
              <div class="service-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
                </svg>
              </div>
              <div class="service-name">100% Digital</div>
              <div class="service-desc">
                Partage de documents en ligne, signature électronique, suivi en temps réel. Zéro paperasse physique, zéro déplacement requis - et ça fonctionne depuis le premier jour.
              </div>
            </div>
            <span class="service-badge">Outils modernes</span>
          </div>

          <!-- Expertise-comptable -->
          <div class="service-card reveal reveal-delay-1">
            <div class="service-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <div class="service-name">Expertise-comptable</div>
            <div class="service-desc">
